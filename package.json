{
  "name": "parsanol-docs",
  "private": true,
  "version": "0.1.0",
  "description": "Documentation website for Parsanol - a high-performance PEG parser library",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate": "node scripts/generate-examples.cjs",
    "generate:benchmarks": "node scripts/generate-backend-benchmarks.cjs",
    "build": "npm run generate && npm run generate:benchmarks && vite build",
    "typecheck": "vue-tsc -b",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "prismjs": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/prismjs": "^1.26.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "vue-tsc": "^2.2.0"
  }
}
